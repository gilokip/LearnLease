# ============================================================
# UniLease Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# Client (for CORS)
CLIENT_URL=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=unilease

# JWT
JWT_SECRET=	your_jwt_secret_key
JWT_EXPIRES=7d

# Bcrypt
BCRYPT_ROUNDS=12
