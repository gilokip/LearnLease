    "express-rate-limit":   "^7.3.1",
    "helmet":               "^7.1.0",
    "jsonwebtoken":         "^9.0.2",
    "mysql2":               "^3.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
